{
  "name": "offshelf",
  "version": "0.1.0",
  "private": true,
  "description": "Offshelf — multi-tenant, Shopify-style storefront platform for high-risk verticals",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,css,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,css,md,json}\"",
    "seed": "tsx scripts/seed.ts",
    "db:check": "tsx scripts/check-counter.ts",
    "test": "node --import tsx --test tests/tenant-isolation.test.ts tests/subdomain.test.ts tests/sanitize.test.ts"
  },
  "dependencies": {
    "lucide-react": "^0.460.0",
    "mongoose": "^8.24.0",
    "next": "15.1.12",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.1.12",
    "eslint-config-prettier": "^9.1.0",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3"
  }
}
