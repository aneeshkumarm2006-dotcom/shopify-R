# ============================================================
# Offshelf — environment variables
# Copy to `.env.local` and fill in. Nothing here is wired in Part A (Stage 0–5);
# each var is consumed by the stage noted. Keep `.env.local` out of git.
# ============================================================

# ---- App / routing (Stage 8) ----
# Apex domain used for wildcard store subdomains: <subdomain>.APP_DOMAIN
NEXT_PUBLIC_APP_DOMAIN=ourapp.com

# ---- MongoDB (Stage 6) ----
MONGODB_URI=
MONGODB_DB=offshelf

# ---- NextAuth + Google OAuth (Stage 7) ----
# Real auth turns on only when all three of SECRET + CLIENT_ID + CLIENT_SECRET are
# set (isAuthConfigured()); otherwise the admin falls back to the demo store so the
# screens still render with no infrastructure. Needs MONGODB_URI too, for first-
# login provisioning. In Google Cloud Console add this authorized redirect URI:
#   http://localhost:3000/api/auth/callback/google   (and the prod equivalent)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Cloudinary media (Stage 9) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ---- Resend transactional email (Stage 13) ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@ourapp.com

# ---- Marketing & lifecycle (Phase 5) ----
# Abandoned-cart recovery cron. Set a long random secret; the scheduler calls
# GET /api/cron/abandoned-carts with `Authorization: Bearer $CRON_SECRET`.
# Unset → the endpoint is disabled (503).
CRON_SECRET=
# SMS campaign seam — STUBBED unless all three are set (generic Twilio-style REST).
# Unset → the SMS channel no-ops; email campaigns still work.
SMS_PROVIDER=
SMS_ENDPOINT=
SMS_AUTH_TOKEN=
SMS_FROM=

# ---- Payments & billing seams (Stage 12 — STUBBED in MVP) ----
# Both streams ship as typed integration seams with no live processing. Leave
# these UNSET in the MVP: storefront orders settle offline as `paymentStatus:
# pending` and subscriptions are provisioned manually. Setting PAYMENTS_PROVIDER
# activates the storefront seam (a future high-risk processor adapter + the
# /api/payments/webhook handler); BILLING_PROVIDER activates platform billing.
# No card data is ever collected in the MVP regardless of these values.
PAYMENTS_PROVIDER=
BILLING_PROVIDER=
